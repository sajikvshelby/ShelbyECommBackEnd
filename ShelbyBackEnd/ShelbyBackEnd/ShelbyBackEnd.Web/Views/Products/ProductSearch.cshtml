@model ProductsVM






<form method="post" class="row" enctype="multipart/form-data">
    <div class="p-3">
              
        <div class="form-floating py-2 col-12">
            <input asp-for="Product.product_name" class="form-control border shadow" />
            <label asp-for="Product.product_name" class="ms-2 fw-bold"> product_name</label>
            <span asp-validation-for="Product.product_name" class="text-danger"></span>
        </div>

        <div class="form-floating py-2 col-12">
            <input asp-for="Product.product_code" class="form-control border shadow" />
            <label asp-for="Product.product_code" class="ms-2 fw-bold"> product_code</label>
            <span asp-validation-for="Product.product_code" class="text-danger"></span>
        </div>

        <div class="form-floating py-2 col-12">
            <input asp-for="Product.product_price" class="form-control border shadow" />
            <label asp-for="Product.product_price" class="ms-2 fw-bold"> product_price</label>
            <span asp-validation-for="Product.product_price" class="text-danger"></span>
        </div>
        <div class="form-floating py-2 col-12">
            <input asp-for="Product.product_weight" class="form-control border shadow" />
            <label asp-for="Product.product_weight" class="ms-2 fw-bold"> product_weight</label>
            <span asp-validation-for="Product.product_weight" class="text-danger"></span>
        </div>
        <div class="form-floating py-2 col-12">
            <input asp-for="Product.tab_product_desc" class="form-control border shadow" />
            <label asp-for="Product.tab_product_desc" class="ms-2 fw-bold"> tab_product_desc</label>
            <span asp-validation-for="Product.tab_product_desc" class="text-danger"></span>
        </div>

    </div>

    <div class="row pt-2 d-flex justify-content-center align-items-center">
        <div class="col-6 col-md-3">
            <button type="submit" asp-action="ProductSearch" class="btn btn-success w-100">
                <i class="bi bi-check-circle"></i>search
            </button>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Categories" asp-action="Index" class="btn btn-secondary w-100"> <i class="bi bi-x-circle"></i>Cancel</a>
                    
        </div>
                   
    </div>
</form>

@if(Model?.Products != null)
{
    <div id="divProduct">
        <partial name="_LoadProducts" model="Model" />
    </div>
}