@using ShelbyBackEnd.Web.Models.ViewModels
@model ProductsVM

@section Scripts {
    <script>
                 $('#dllpagesize').on('change', function() {
                
                  window.location.href ='/Products/Index?ps=' + $('#dllpagesize').val() + "&pt=" + $('#dllpageType').val();
                });

            $('#dllpageType').on('change', function() {
             var id = $(this).val();
           window.location.href ='/Products/Index?ps=' + $('#dllpagesize').val() + "&pt=" + id;
        });
    </script>
}

<div class="w-100 card border-0 p-4">
    <div class="card-header bg-success bg-gradient m-lg-0 py-3">
        <div class="row">
            <div class="col text-center">
                <h2 class="text-white py-2">All Products</h2>

            </div>
        </div>
    </div>

</div>

<div class="text-start">
    <select id="dllpageType" asp-for="@Model.pageType" style="width: 250px;" class="form-select">
        <option value="1">Products</option>
        <option value="2">Low Inventory</option>
        <option value="3">Queued for PO</option>
        <option value="4">Search</option>
        <option value="5">Add</option>
    </select>
</div>

<div id="divProduct" style="display: @(Model.isProducts ? "block" : "none")">
    <partial name="_Products" model="Model" />
</div>

<script>

    function NoImg(i) {

          i.src = "../images/nophoto.gif";
      }
</script>