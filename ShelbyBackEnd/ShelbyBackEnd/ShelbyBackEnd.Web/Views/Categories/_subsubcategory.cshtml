
@model Select_All_CategoriesResult


<div class="row w-100">
                                   
    <div class="col">@Model.category_id</div>
    <div class="col">@Model.category_name</div>
    <div class="col">

        <div class="w-75 btn-group  " role="group">

               
            <a class="btn btn btn-success mx-2 "
                   onclick="event.stopPropagation(); location.href='@Url.Action("UpdateCategories", "Categories", new { pid = @Model.parent_category_id, cid = @Model.category_id, ctg = "3" })'">
                Edit
            </a>

                                        
           

            <a class="btn btn-danger mx-2" onclick="event.stopPropagation(); setDelete('@Model.category_id','@Model.category_name');" data-bs-toggle="modal" data-bs-target="#deleteModal">
                Delete
            </a>


                                     
        </div>
    </div>
                               
</div>