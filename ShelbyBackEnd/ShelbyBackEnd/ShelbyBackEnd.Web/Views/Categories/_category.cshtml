@using ShelbyBackEnd.Infrastructure.Models
@model Select_CategoriesResult


<div class="row w-100">
                                   
    <div class="col">@Model.category_id</div>
    <div class="col">@Model.category_name</div>
    <div class="col">

        <div class="w-75 btn-group  " role="group">

            <a class="btn btn-secondary"
                   onclick="event.stopPropagation(); location.href='@Url.Action("CreateCategories", "Categories", new { categoryid = @Model.category_id })'">
                Create Sub
                </a>
                               
            <a class="btn btn btn-success mx-2 "
                   onclick="event.stopPropagation(); location.href='@Url.Action("UpdateCategories", "Categories", new { categoryid = @Model.category_id })'">
                Edit
            </a>

                                        
            <a class="btn btn-danger mx-2"
                   onclick="event.stopPropagation(); location.href='@Url.Action("DeleteCategories", "Categories", new { categoryid = @Model.category_id })'">
                Delete
            </a>

                                     
        </div>
    </div>
                               
</div>