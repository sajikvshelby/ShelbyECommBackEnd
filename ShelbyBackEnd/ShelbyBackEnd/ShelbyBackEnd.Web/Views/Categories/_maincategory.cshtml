@using ShelbyBackEnd.Web.Models.ViewModels
@model CategoriesVM




<div>
    <div class="form-floating py-2 col-12">
        <input asp-for="Category.category_name" class="form-control border shadow" required="required" />
        <label asp-for="Category.category_name" class="ms-2"> @Model.Title Category Name</label>
        <span asp-validation-for="Category.category_name" class="text-danger"></span>
    </div>
           
    <div class="form-floating py-2 col-12">
                    
        <select id="parent_category" asp-for="Category.parent_category_id" asp-items="@Model.categoryList" class="form-control form-select border shadow">
            <option value="">--Select Parent Category--</option>
        </select>
        <label asp-for="Category.parent_category_id" class="ms-2">Parent Category</label>
    </div>
    @if (@Model.Title != "Sub")
    {
        <div class="form-floating py-2 col-12">
            <select id="sub_category" asp-for="Category.category_id" asp-items="@Model.subCategoryList" class="form-control form-select border shadow">
                <option value="">--Select  Sub category--</option>
            </select>
            <label asp-for="Category.category_id" class="ms-2">Sub category</label>
        </div>
    }

    <div class="form-floating py-2 col-12">
                    
        <div>  <input type="checkbox" class="me-3" asp-for="Category.hidden" />   Hidden </div>
    </div>
    <div class="container">
        <div class="row flex-nowrap overflow-auto py-3">

            <button type="button" id="btn-1" class="col-2 btn btn-secondary content-button" onclick="showOnly('1')">Category Descriptions</button>
            <button type="button" id="btn-2" class="col-3 btn btn-secondary content-button" onclick="showOnly('2')">Search Engine Optimization</button>
            <button type="button" id="btn-3" class="col-2 btn btn-secondary content-button" onclick="showOnly('3')">Category Display</button>
            @* <button type="button" id="btn-4" class="col-2 btn btn-secondary content-button" onclick="showOnly('4')">Subcategory Display</button> *@
            <button type="button" id="btn-4" class="col-2 btn btn-secondary content-button" onclick="showOnly('4')">Product Display</button>
            <button type="button" id="btn-5" class="col-2 btn btn-secondary content-button" onclick="showOnly('5')">Misc</button>
        </div>
        <div class="d-flex justify-content-center align-items-center fw-bold text-decoration-underline">Advanced Info</div>
    </div>

    <div>
        <div id="1" class="content-box"> <partial name="_CategoryDescriptions" model="@Model" /></div>
        <div id="2" class="content-box" style="display:none;"><partial name="_SearchEngineOptimization" model="@Model" /></div>
        <div id="3" class="content-box" style="display:none;"><partial name="_CategoryDisplay" model="@Model" /></div>
        @* <div id="4" class="content-box" style="display:none;"><partial name="_SubcategoryDisplay" model="@Model" />  </div> *@
        <div id="4" class="content-box" style="display:none;"><partial name="_ProductDisplay" model="@Model" /></div>
        <div id="5" class="content-box" style="display:none;"><partial name="_Misc" model="@Model" /></div>
    </div>
</div>